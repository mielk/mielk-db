{
	"compilerOptions": {
		"module": "nodenext",
		"moduleResolution": "NodeNext",
		"target": "ES6",
		"declaration": true,
		"outDir": "dist",
		"rootDir": "src",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["jest"]
	},
	"baseUrl": ".",
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
